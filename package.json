    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vite-plugin-vue-setup-extend": "^0.4.0",
    "vue": "^3.5.25",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
