{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.vue",
    "src/preload/*.d.ts",
    "src/shared/**/*",
    "src/i18n/**/*",
    "auto-imports.d.ts",
    "components.d.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "types": [
      "vite/client"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/renderer/src/*"
      ],
      "@renderer/*": [
        "src/renderer/src/*"
      ],
      "#build/ui/*": [
        "src/renderer/node_modules/.nuxt-ui/ui/*"
      ],
      "@shared/*": [
        "src/shared/*"
      ],
      "@i18n/*": [
        "src/i18n/*"
      ],
      "~/*": [
        "./*"
      ]
    }
  }
}
